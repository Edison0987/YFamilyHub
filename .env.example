# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values from your Supabase
# project (Dashboard → Project Settings → API).
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Secret — SERVER ONLY. Used by the cron route and admin invite action.
# Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Secret used to protect the cron endpoint. Generate any random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET="generate-a-long-random-string"
